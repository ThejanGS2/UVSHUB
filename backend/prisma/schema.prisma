generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Enrollments {
  id           BigInt   @id @default(autoincrement())
  created_at   DateTime @default(now()) @db.Timestamptz
  Student_ID   BigInt?
  Studnet_Name String?
  Subject_Name String?
}

model Payments {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz
  Subject    String
  Student_ID BigInt
  Amount     Decimal
  Method     String
}

model Studnets {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at      DateTime @default(now()) @db.Timestamptz
  Student_ID      BigInt
  Name            String
  Email           String
  Password        String
  Watsapp_Number  String
  NIC             Decimal?
  Gurdian_s_Name  String   @map("Gurdian's_Name")
  Gurdians_Number String
  Address         String
}

model Subjects {
  id         BigInt  @id @default(autoincrement())
  Name       String
  Grade      Decimal
  Price      Decimal
  Instructor String
  Medium     String
}
