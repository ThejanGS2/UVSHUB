generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Enrollments {
  id           BigInt   @id @default(autoincrement())
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  Student_ID   BigInt?
  Studnet_Name String?
  Subject_Name String?

  @@unique([Student_ID, Subject_Name], map: "Enrollments_Student_Subject_key")
}

model Payments {
  id         BigInt         @id @default(autoincrement())
  created_at DateTime       @default(now()) @db.Timestamptz(6)
  Subject    String
  Student_ID BigInt
  Amount     Decimal
  Method     String
  Status     paymentStatus? @default(Pending)
}

model Student {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  Student_ID      BigInt   @unique @default(autoincrement())
  Name            String   @unique
  Email           String
  Watsapp_Number  String
  NIC             Decimal?
  Gurdian_s_Name  String   @map("Gurdian's_Name")
  Gurdians_Number String
  Address         String
  Role            String   @default("student")

  @@map("Studnets")
}

model Subjects {
  id          BigInt  @id @default(autoincrement())
  Name        String  @unique
  Grade       Decimal
  Price       Decimal
  Instructor  String
  Medium      String
  MeetingLink String
}

enum paymentStatus {
  Approved
  Rejected
  Pending
}
